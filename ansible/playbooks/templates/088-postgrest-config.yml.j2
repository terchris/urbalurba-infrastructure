# Per-app PostgREST Deployment + Service.
# Rendered by 088-setup-postgrest.yml with extra-vars:
#   _app_name    — per-app instance name (k8s-safe), e.g. "atlas"
#   _url_prefix  — first label of the public hostname (used by the IngressRoute, not here)
#
# The schema list (PGRST_DB_SCHEMAS) is no longer a Jinja substitution — it
# lives as a key on the per-app secret <app>-postgrest, written by
# configure-postgrest.sh. The Deployment mounts both PGRST_DB_URI and
# PGRST_DB_SCHEMAS via valueFrom.secretKeyRef. If either key is missing, the
# pod CrashLoopBackOffs with a clear "couldn't find key" event — that's the
# operator's signal to run `./uis configure postgrest --app <name> --schemas <list>`.
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: "{{ _app_name }}-postgrest"
  namespace: postgrest
  labels:
    app.kubernetes.io/name: postgrest
    app.kubernetes.io/instance: "{{ _app_name }}"
    app.kubernetes.io/managed-by: uis
spec:
  replicas: 2
  selector:
    matchLabels:
      app.kubernetes.io/name: postgrest
      app.kubernetes.io/instance: "{{ _app_name }}"
  template:
    metadata:
      labels:
        app.kubernetes.io/name: postgrest
        app.kubernetes.io/instance: "{{ _app_name }}"
    spec:
      containers:
        - name: postgrest
          image: postgrest/postgrest:v14.10
          imagePullPolicy: IfNotPresent
          ports:
            - name: api
              containerPort: 3000
            - name: admin
              containerPort: 3001
          env:
            - name: PGRST_DB_URI
              valueFrom:
                secretKeyRef:
                  name: "{{ _app_name }}-postgrest"
                  key: PGRST_DB_URI
            - name: PGRST_DB_SCHEMAS
              valueFrom:
                secretKeyRef:
                  name: "{{ _app_name }}-postgrest"
                  key: PGRST_DB_SCHEMAS
            - name: PGRST_DB_ANON_ROLE
              value: "{{ _app_name | replace('-', '_') }}_web_anon"
            - name: PGRST_DB_POOL
              value: "10"
            - name: PGRST_ADMIN_SERVER_PORT
              value: "3001"
            - name: PGRST_SERVER_CORS_ALLOWED_ORIGINS
              value: "*"
          livenessProbe:
            httpGet:
              path: /live
              port: 3001
            initialDelaySeconds: 5
            periodSeconds: 10
          readinessProbe:
            httpGet:
              path: /ready
              port: 3001
            initialDelaySeconds: 2
            periodSeconds: 5
          resources:
            requests:
              cpu: 50m
              memory: 64Mi
            limits:
              cpu: 500m
              memory: 256Mi
---
apiVersion: v1
kind: Service
metadata:
  name: "{{ _app_name }}-postgrest"
  namespace: postgrest
  labels:
    app.kubernetes.io/name: postgrest
    app.kubernetes.io/instance: "{{ _app_name }}"
    app.kubernetes.io/managed-by: uis
spec:
  type: ClusterIP
  ports:
    - name: api
      port: 3000
      targetPort: 3000
  selector:
    app.kubernetes.io/name: postgrest
    app.kubernetes.io/instance: "{{ _app_name }}"
