# File: platforms/aks/tofu/terraform.tfvars.example
#
# DO NOT edit this file directly.
# Values are injected automatically from azure-aks-config.sh by scripts/01-apply.sh
# using a generated terraform.tfvars at apply time.
#
# This file documents what variables are set — useful for understanding
# or for running tofu manually outside the scripts.

tenant_id       = "your-tenant-id"
subscription_id = "your-subscription-id"

resource_group  = "rg-urbalurba-aks-weu"
cluster_name    = "azure-aks"
location        = "westeurope"

node_count      = 1
node_size       = "Standard_B2ms"
min_count       = 1
max_count       = 3
os_disk_size_gb = 30

tag_cost_center    = "your-cost-center"
tag_project        = "urbalurba-infrastructure"
tag_environment    = "Production"
tag_business_owner = "your-email@organization.com"
tag_it_owner       = "your-email@organization.com"
