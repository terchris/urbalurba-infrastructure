# UIS Default Secrets
# These are DEVELOPMENT DEFAULTS for localhost testing only.
# DO NOT use these in production!
#
# For production, create your own secrets in .uis.secrets/
#
# PASSWORD RESTRICTION: Do NOT use these characters in passwords:
#   !  $  `  \  "
# Bitnami Helm charts pass passwords through bash during container
# initialization, which escapes these characters. For example, "Pass!"
# becomes "Pass\!" in the database, causing authentication failures.

# Admin credentials
DEFAULT_ADMIN_EMAIL=post@helpers.no
DEFAULT_ADMIN_PASSWORD=LocalDev@123

# Database credentials
DEFAULT_DATABASE_PASSWORD=LocalDevDB456

# Redis
DEFAULT_REDIS_PASSWORD=LocalDevRedis123

# Authentik
DEFAULT_AUTHENTIK_SECRET_KEY=LocalDevAuthentikSecret123
DEFAULT_AUTHENTIK_BOOTSTRAP_PASSWORD=LocalDevAuthentik123

# Cloudflare
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# OpenWebUI
DEFAULT_OPENWEBUI_SECRET_KEY=LocalDevOpenWebUI123

# ----------------------------------------------------------------------
# System-wide config knobs (NOT secrets — feature flags / cluster shape)
# ----------------------------------------------------------------------
# Variables in this section are forwarded by service-deployment.sh as
# lowercased ansible extra-vars to every setup playbook (DEFAULT_FOO is
# available as {{ default_foo }} inside playbooks). Adopting services
# read them in their `vars:` block and apply them however they need —
# helm --set, chart-values overrides, env injection, etc.
#
# Default values target a single-laptop dev cluster. Production-shaped
# clusters override the values they care about.
#
# Adoption procedure for a new system-wide knob:
#   1. Define DEFAULT_<NAME> here with a comment explaining its intent.
#   2. In each adopting playbook's vars block, map it to a per-service
#      var: `_<service>_<name>: "{{ default_<name> | default('...') }}"`.
#   3. Use the per-service var inside that playbook's tasks.
#   4. Add the service name to the "Currently adopted by" list below.
#
# DEFAULT_AUTOSCALING — controls Kubernetes HorizontalPodAutoscaler
# creation for services that ship one. UIS local-dev defaults to off
# (chart-default HPAs scale up under modest memory pressure on laptops,
# producing redundant replicas). Flip to true in prod-shaped clusters.
# Currently adopted by: gravitee.
DEFAULT_AUTOSCALING=false

# DEFAULT_ORGANIZATION_NAME — human-readable label for the cluster's
# tenant/organisation, surfaced in service UIs (Gravitee Console org
# name today; Authentik tenants, Grafana orgs, Backstage app.title to
# follow). Customise per-install via the per-install common-values
# template; this image-default is what fresh installs see.
# Currently adopted by: gravitee.
#
# QUOTING REQUIRED: this file is `source`d by first-run.sh and by
# `./uis secrets generate`. Multi-word values must be quoted, otherwise
# bash interprets the trailing words as a command. Single-word values
# above are unquoted (legacy); add quotes to any new multi-word entry.
DEFAULT_ORGANIZATION_NAME="UIS Local Dev"
